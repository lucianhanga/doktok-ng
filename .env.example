# DokTok NG configuration (copy to .env and adjust). Never commit a real .env.

# Environment
DOKTOK_ENV=local

# Database (PostgreSQL 17 + pgvector)
DOKTOK_DATABASE_URL=postgresql://doktok:doktok@localhost:5432/doktok
# Host port the docker-compose Postgres binds to (override if 5432 is already in use).
# DOKTOK_DB_PORT=5433

# Filesystem storage root (document lifecycle folders live under here)
DOKTOK_FILES_ROOT=./storage/files

# Ollama models (configurable; defaults below are confirmed local tags)
DOKTOK_DEFAULT_MODEL=qwen3.6:35b-a3b
DOKTOK_EMBEDDING_MODEL=qwen3-embedding:0.6b
# Context window (tokens) for embedding calls. Chunks are ~300 tokens, so capping the embedding
# context (the model's own default is 32k) frees GPU KV-cache without changing the embeddings.
DOKTOK_EMBEDDING_NUM_CTX=1024
# Document enrichment (M6.2). Dense default = fast (think=false works with structured output).
# The OCR-quality judge and the Ollama JSON-repair step both reuse the configured pipeline model,
# so ingestion never loads the 23 GB qwen3.6:
DOKTOK_JUDGE_MODEL=qwen3:14b
DOKTOK_ENRICH_MODEL=qwen3:14b
DOKTOK_ENRICH_THINK=false
# Higher quality but ~5-10x slower (MoE keeps thinking; /no_think only soft-trims it):
#   DOKTOK_ENRICH_MODEL=qwen3.6:35b-a3b
#   DOKTOK_ENRICH_THINK=true

# OCR vision model (M3). Default glm-ocr:latest (2.2GB, dedicated OCR, emits Markdown/JSON/LaTeX).
# Alternatives: qwen3-vl:8b (broader VLM, RTL), qwen2.5vl:7b.  Pull: ollama pull glm-ocr:latest
# OCR engine: paddleocr (detect+recognize, no repeat-loops, native confidence; needs the
# extra: `make ocr-paddle`) or glm-ocr (Ollama vision model).
DOKTOK_OCR_ENGINE=paddleocr
DOKTOK_OCR_LANG=german
DOKTOK_OCR_MODEL=glm-ocr:latest
# OCR context per single-page call (8192 fits a page; 16384 for very dense/multi-column).
DOKTOK_OCR_NUM_CTX=8192
DOKTOK_OCR_NUM_PREDICT=8192
DOKTOK_OCR_KEEP_ALIVE=5m
# Local Gotenberg container that converts office documents (docx/xlsx/pptx) to PDF on ingest (#313).
# Override the host port with DOKTOK_GOTENBERG_PORT in docker-compose.
DOKTOK_GOTENBERG_URL=http://localhost:3000
DOKTOK_OLLAMA_BASE_URL=http://localhost:11434
# HTTP timeout (seconds) per Ollama call. Generous because requests queue under parallel
# ingestion. Run Ollama with OLLAMA_NUM_PARALLEL=N (e.g. OLLAMA_NUM_PARALLEL=4 ollama serve)
# to actually serve requests concurrently instead of queuing (that is an Ollama-side var).
DOKTOK_OLLAMA_TIMEOUT_SECONDS=600
# Context window (tokens) for the chat/RAG model only (qwen); OCR/embeddings use defaults.
DOKTOK_CHAT_NUM_CTX=32768
# Keep the 23 GB RAG model resident so idle chat doesn't pay a ~14s cold reload ("-1" = never evict).
DOKTOK_CHAT_KEEP_ALIVE=30m
# Enrichment context window. 8192 fits the ~12-16k-char document head (4096 silently truncated
# German text, dropping the title/date region the extractors read).
DOKTOK_ENRICH_NUM_CTX=8192
# Keep the dense enrichment model warm across a batch ingest.
DOKTOK_ENRICH_KEEP_ALIVE=30m
# RAG: retrieve this many candidates, then the LLM reranker keeps the best (chat limit).
DOKTOK_RAG_RETRIEVE_K=40
# Reranker model (empty => DOKTOK_DEFAULT_MODEL; set a smaller model to free the chat slot) and a
# tight output cap (the listwise rerank call only emits a short JSON array).
DOKTOK_RERANK_MODEL=
DOKTOK_RERANK_NUM_PREDICT=64
# Deterministic evidence floor: refuse before generating if the best retrieval score is below this
# (0 = disabled; RRF scores are ~0.01-0.05, tune against the eval set before raising).
DOKTOK_RAG_MIN_SCORE=0
# API DB connection pool size (sync routes hold a connection during a slow Ollama call).
DOKTOK_API_DB_POOL_SIZE=10
# Per-call timeout (seconds) for the interactive RAG path (shorter than the ingestion timeout).
DOKTOK_RAG_TIMEOUT_SECONDS=120
# A PDF page whose largest image covers >= this fraction of the page is treated as scanned and
# re-OCR'd (dropping weak embedded OCR text layers). Set > 1.0 to OCR only text-less pages.
DOKTOK_OCR_IMAGE_COVERAGE=0.8
# On a scanned page with an embedded text layer: keep it if quality >= this; otherwise OCR and let
# the default LLM (DOKTOK_DEFAULT_MODEL) judge which text is better. Set 0 to always ask the LLM.
DOKTOK_OCR_MIN_TEXT_QUALITY=0.5
# Max significant lexemes indexed per document as keyword (CUSTOM_TOKEN) entities (multilingual,
# stopwords removed via PostgreSQL to_tsvector in the document's detected language).
DOKTOK_LEXICAL_TERMS_LIMIT=200
# Lighter alternative for ~16GB machines: DOKTOK_DEFAULT_MODEL=qwen3:14b
# Alternative embedding (8K context, multilingual): DOKTOK_EMBEDDING_MODEL=bge-m3:latest

# Security posture (local-first, no egress by default)
DOKTOK_NO_EGRESS=true

# Authentication and multi-tenancy (ADR-0007/0008)
# API server bind host (loopback by default; non-loopback requires tokens, fail-closed).
DOKTOK_BIND_HOST=127.0.0.1
# Bearer token -> tenant_id map as JSON. Use long random tokens in real deployments.
# 'default' is the UI/dev tenant; 'developer' is for manual API testing; 'test' is used by the
# automated DB integration tests (cleanup only touches tenant ids starting with 'test').
DOKTOK_TENANT_TOKENS={"dev-token-default":"default","dev-token-developer":"developer","dev-token-test":"test"}
# Token the UI dev proxy injects into proxied API calls (must match one above).
DOKTOK_DEV_TOKEN=dev-token-default
# Optional: separate database for DB integration tests (falls back to DOKTOK_DATABASE_URL).
# DOKTOK_TEST_DATABASE_URL=postgresql://doktok:doktok@localhost:5432/doktok_test

# Ingestion limits
DOKTOK_MAX_FILE_MB=200
DOKTOK_MAX_PAGES=500
DOKTOK_FILE_STABILITY_SECONDS=3
# How many stable files the worker processes in parallel (1 = sequential; tune to Ollama parallelism).
DOKTOK_INGEST_CONCURRENCY=2
# How many PDF pages OCR concurrently within a single document (PaddleOCR is CPU-bound). Also sizes
# the PaddleOCR predictor pool. Raise toward the CPU core count to use idle cores on big scans.
DOKTOK_OCR_CONCURRENCY=4
# How many feature-reconciler runs proceed in parallel (SKIP LOCKED makes this safe).
DOKTOK_RECONCILE_CONCURRENCY=2
# Reconciler parallelism used when the pipeline runs on OpenAI (remote): enrichment is network-bound
# and the API handles high concurrency, so fan out wider than the local-Ollama default above.
DOKTOK_OPENAI_RECONCILE_CONCURRENCY=10
# A job stuck in a non-terminal state longer than this (minutes) was abandoned by a killed worker
# and is auto-re-queued on the next worker start (0 = disable recovery).
DOKTOK_STALE_JOB_MINUTES=10
