# =============================================================================
# DokTok NG - production env profile (hybrid on-prem box, e.g. the TRIGKEY N95).
# =============================================================================
# This is the TEMPLATE. To use it on the box:
#
#   cp .env.production.example .env.production
#   # edit .env.production, fill in every value marked REQUIRED
#   chmod 600 .env.production
#
# .env.production itself is gitignored (only this *.example is tracked) and is a
# one-time MANUAL bootstrap on the box - `make deploy-box` deliberately never
# rsyncs it, so it is never overwritten. See the fresh-box runbook section 3:
# docs/operations/deploy-fresh-box-runbook.md
#
# Generate strong random secrets with:  openssl rand -hex 32
# Store the restic / pgBackRest passphrases OFF the box too - a backup repo is
# unrecoverable without them.
#
# Consumed by: docker compose -f docker-compose.prod.yml --env-file .env.production ...
# =============================================================================


# --- Image -------------------------------------------------------------------
# Image tag to run. "latest" works for build-on-box; the deploy workflow can
# pin a digest that passed staging. (optional, default: latest)
DOKTOK_IMAGE_TAG=latest


# --- REQUIRED secrets --------------------------------------------------------
# Postgres superuser password for the bundled db container.            REQUIRED
DOKTOK_DB_PASSWORD=replace-with-a-strong-password

# Bearer-token -> tenant map (JSON). Each token authenticates one tenant.
# Generate a long random token per tenant.                             REQUIRED
DOKTOK_TENANT_TOKENS={"replace-with-a-long-random-token":"default"}

# Token Caddy injects for same-origin browser calls. MUST be one of the keys in
# DOKTOK_TENANT_TOKENS above.                                          REQUIRED
DOKTOK_API_TOKEN=replace-with-a-long-random-token

# Fernet-style key that encrypts the stored OpenAI key at rest (APP-8). REQUIRED
DOKTOK_SECRETS_KEY=replace-with-a-long-random-value

# REQUIRED (recommended): a dedicated secret for signing session JWTs (ADR-0024). When unset,
# the backend falls back to a purpose-separated subkey of DOKTOK_SECRETS_KEY (#631); a dedicated
# value keeps session signing fully independent from the envelope-encryption key and lets you
# rotate sessions without re-keying stored secrets. Generate: openssl rand -base64 48
DOKTOK_AUTH_JWT_SECRET=replace-with-a-second-long-random-value


# --- AI provider split (hybrid: local OCR/embeddings + remote enrichment/RAG)-
# The provider split + OpenAI key are DB-backed and live-editable in the
# Settings UI. The vars below only SEED them on a FIRST/empty DB (APP-2); leave
# a provider BLANK to keep whatever the Settings UI has stored.
#
# Two supported topologies:
#   (a) OpenAI       -> set the providers to "openai" and supply the key below.
#   (b) remote Ollama-> leave the providers BLANK here and point pipeline/RAG/
#                       embedding at a LAN Ollama URL in Settings (the N95 does
#                       this; its in-stack ollama container then auto-stops).
#
# Egress to OpenAI must be allowed for topology (a). false = allowed.
DOKTOK_NO_EGRESS=false

# Seed values (optional; blank = use stored Settings). Examples for topology (a):
DOKTOK_PIPELINE_PROVIDER=
DOKTOK_PIPELINE_MODEL=gpt-4o-mini
DOKTOK_RAG_PROVIDER=
DOKTOK_RAG_MODEL=gpt-4o-mini

# OpenAI key. REQUIRED only if a provider above is "openai"; otherwise blank.
DOKTOK_OPENAI_API_KEY=


# --- OCR (always local) ------------------------------------------------------
# Engine: "rapidocr" (recommended on the N95 / weak CPUs - ONNX/OpenVINO, much
# faster) or "paddleocr". (optional, default: rapidocr)
DOKTOK_OCR_ENGINE=rapidocr
# RapidOCR backend: "openvino" (Intel; fastest on Alder Lake-N) or "onnxruntime".
DOKTOK_OCR_RAPID_BACKEND=openvino
# PaddleOCR only: on N95 / Alder Lake-N, oneDNN crashes under the PIR executor,
# so disable mkldnn if you switch DOKTOK_OCR_ENGINE=paddleocr.
DOKTOK_OCR_ENABLE_MKLDNN=false
# OCR pages processed in parallel, and CPU threads per OCR worker.
DOKTOK_OCR_CONCURRENCY=2
DOKTOK_OCR_CPU_THREADS=1

# Ingestion parallelism and OpenAI reconcile concurrency. (optional)
DOKTOK_INGEST_CONCURRENCY=2
DOKTOK_OPENAI_RECONCILE_CONCURRENCY=6
# Hard ceiling on concurrent OpenAI requests across the whole worker (reconciler + OCR judge) and
# the backend (RAG) - the 429 guard. Set to match your OpenAI tier's rate limit; lower it if you
# still see "rate limit exceeded (HTTP 429)". Should be >= the reconcile concurrency above.
DOKTOK_OPENAI_MAX_CONCURRENCY=5


# --- TLS / exposure ----------------------------------------------------------
# A real domain enables Caddy's automatic HTTPS. Use the box IP or :80 for LAN.
DOKTOK_SITE_ADDRESS=docs.example.com
DOKTOK_CORS_ORIGINS=["https://docs.example.com"]
# Published host ports for Caddy. (optional, defaults: 80 / 443)
DOKTOK_HTTP_PORT=80
DOKTOK_HTTPS_PORT=443


# --- Hardening / observability ----------------------------------------------
DOKTOK_RATE_LIMIT_PER_MINUTE=120
DOKTOK_MAX_REQUEST_MB=25
DOKTOK_LOG_FORMAT=json
DOKTOK_LOG_LEVEL=INFO


# --- Backups / DRP (M12; local-first, optional Azure offsite) ----------------
# Host dir for the local backup repos + DRP status sentinels. The backend mounts
# it read-only; the systemd timers write it. (default: ./backups)
DOKTOK_BACKUP_DIR=/var/lib/doktok/backups
# Portable one-file backup (M12 Phase 1): WRITABLE dir where the backend stages
# the plaintext export before streaming it out encrypted. Must be a separate
# writable volume (backup_dir above is mounted read-only). Compose maps this to
# the doktok-exports volume. (default: <backup_dir>/exports)
DOKTOK_BACKUP_EXPORT_DIR=/var/lib/doktok/exports
# Topology for backups/DRP: "compose" on this box; dev/test uses "host".
DOKTOK_DEPLOY_MODE=compose
# Repo encryption passphrases. REQUIRED to run backups; store BOTH off the box.
DOKTOK_RESTIC_PASSWORD=replace-with-a-long-random-value
DOKTOK_PGBACKREST_CIPHER_PASS=replace-with-a-long-random-value
# Offsite (Azure Blob) - optional / deferred. Provision with
# deploy/azure-provision.sh and use a write-scoped SAS.
DOKTOK_AZURE_ACCOUNT=
DOKTOK_AZURE_CONTAINER=doktok-backups
DOKTOK_AZURE_SAS=
