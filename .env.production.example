# Production env profile for the hybrid N95 deployment (M11 #340 / DEVOPS-11).
# Copy to .env.production, fill in the secrets, and keep it OUT of git (.env.* is gitignored).
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# The AI provider split + OpenAI key are DB-backed; the values below SEED them on a fresh DB (APP-2)
# and the Settings UI is the live-editable surface afterward. See
# docs/operations/deployment-trigkey-n95.md and docs/operations/security-runbook.md.

# Image tag/digest to run (the deploy workflow sets this to a digest that passed staging).
DOKTOK_IMAGE_TAG=latest

# --- Secrets (REPLACE all of these) ---
DOKTOK_DB_PASSWORD=replace-with-a-strong-password
DOKTOK_TENANT_TOKENS={"replace-with-a-long-random-token":"default"}
DOKTOK_API_TOKEN=replace-with-a-long-random-token   # MUST be one of DOKTOK_TENANT_TOKENS
DOKTOK_SECRETS_KEY=replace-with-a-long-random-value  # encrypts the OpenAI key at rest (APP-8)
DOKTOK_OPENAI_API_KEY=sk-...

# --- Hybrid AI split (egress to OpenAI is required and deliberate) ---
DOKTOK_NO_EGRESS=false
DOKTOK_PIPELINE_PROVIDER=openai
DOKTOK_PIPELINE_MODEL=gpt-4o-mini
DOKTOK_RAG_PROVIDER=openai
DOKTOK_RAG_MODEL=gpt-4o-mini

# --- TLS / exposure --- (a domain enables automatic HTTPS)
DOKTOK_SITE_ADDRESS=docs.example.com
DOKTOK_CORS_ORIGINS=["https://docs.example.com"]

# --- N95 tuning ---
DOKTOK_OCR_CONCURRENCY=2
DOKTOK_OCR_CPU_THREADS=1
DOKTOK_INGEST_CONCURRENCY=2
DOKTOK_OPENAI_RECONCILE_CONCURRENCY=6

# --- Hardening / observability ---
DOKTOK_RATE_LIMIT_PER_MINUTE=120
DOKTOK_MAX_REQUEST_MB=25
DOKTOK_LOG_FORMAT=json
DOKTOK_LOG_LEVEL=INFO
