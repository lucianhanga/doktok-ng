# Staging env profile for the hybrid N95 deployment (M11 #340 / DEVOPS-11).
# Copy to .env.staging, fill in secrets, keep OUT of git. Same stack as production with a separate
# DB/files volume, a staging OpenAI key (set a low spend cap on it), and LAN/self-signed TLS.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.staging up -d
#
# Promotion: deploy the SAME image digest to production once validated here - never rebuild between
# environments (see docs/operations/deployment-trigkey-n95.md).

DOKTOK_IMAGE_TAG=latest

# --- Secrets (REPLACE) ---
DOKTOK_DB_PASSWORD=replace-staging-password
DOKTOK_TENANT_TOKENS={"replace-staging-token":"default"}
DOKTOK_API_TOKEN=replace-staging-token
DOKTOK_SECRETS_KEY=replace-staging-secrets-key
DOKTOK_OPENAI_API_KEY=sk-...   # a staging key with a low spend cap

# --- Hybrid AI split ---
DOKTOK_NO_EGRESS=false
DOKTOK_PIPELINE_PROVIDER=openai
DOKTOK_PIPELINE_MODEL=gpt-4o-mini
DOKTOK_RAG_PROVIDER=openai
DOKTOK_RAG_MODEL=gpt-4o-mini

# --- TLS / exposure --- (no public domain: an https:// LAN host + `tls internal` in apps/ui/Caddyfile)
DOKTOK_SITE_ADDRESS=https://doktok.staging.lan
DOKTOK_CORS_ORIGINS=["https://doktok.staging.lan"]

# --- N95 tuning ---
DOKTOK_OCR_CONCURRENCY=2
DOKTOK_OCR_CPU_THREADS=1
DOKTOK_INGEST_CONCURRENCY=2
DOKTOK_OPENAI_RECONCILE_CONCURRENCY=6

# --- Hardening / observability ---
DOKTOK_RATE_LIMIT_PER_MINUTE=0    # off in staging for easier testing
DOKTOK_MAX_REQUEST_MB=25
DOKTOK_LOG_FORMAT=json
DOKTOK_LOG_LEVEL=DEBUG

# --- Backups (M12). Use a SEPARATE Azure container/keys from production. Keys also stored off-box.
DOKTOK_BACKUP_DIR=/var/lib/doktok/backups
DOKTOK_RESTIC_PASSWORD=replace-staging-restic-pw
DOKTOK_PGBACKREST_CIPHER_PASS=replace-staging-pgbackrest-pw
DOKTOK_AZURE_ACCOUNT=
DOKTOK_AZURE_CONTAINER=doktok-backups-staging
DOKTOK_AZURE_SAS=
