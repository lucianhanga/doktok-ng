# Caddy config for the DokTok NG UI image (M11 #317/#318/#321).
# Serves the built SPA and reverse-proxies the API, injecting the bearer token so the token-free
# bundle can call /api (mirrors the Vite dev proxy).
#
# TRUST BOUNDARY (#616, F-04): the injected DOKTOK_API_TOKEN is a PLATFORM credential (ADR-0025) -
# every request without its own Authorization runs as the platform owner. Restrict who can reach
# this port (trusted LAN, firewall, tailnet, or an authenticated external proxy), or enable login
# (DOKTOK_AUTH_JWT_SECRET) so each user presents their own JWT - which is now passed THROUGH
# untouched (the injection fires only when the client sent no Authorization header).
#
# TLS (#321): the site address comes from DOKTOK_SITE_ADDRESS.
#   - ":80"               -> plain HTTP (default; put behind a trusted LAN or an external TLS proxy)
#   - "docs.example.com"  -> automatic HTTPS via Let's Encrypt (the box must be reachable on 443)
#   - LAN host, no public domain -> set DOKTOK_SITE_ADDRESS to an https:// host and uncomment the
#     `tls internal` line below for a self-signed (Caddy local CA) certificate.
{
	admin off
}

{$DOKTOK_SITE_ADDRESS::80} {
	encode zstd gzip
	# tls internal   # uncomment for a self-signed cert on a LAN host without a public domain

	# API + health endpoints -> backend. Inject the tenant bearer token ONLY when the client sent
	# no Authorization of its own (#616): a logged-in user's JWT flows through unchanged, so
	# per-user RBAC and platform flags work end-to-end; the token-free bundle still works.
	@api path /api/* /health /ready
	handle @api {
		@no_client_token not header Authorization *
		header @no_client_token >Authorization "Bearer {$DOKTOK_API_TOKEN}"
		reverse_proxy {$DOKTOK_BACKEND_URL:backend:8000}
	}

	# Everything else is the SPA (client-side routing -> index.html fallback).
	handle {
		root * /srv
		try_files {path} /index.html
		# F-22 (#636): hardening headers for the app shell. The SPA must NEVER be framed -
		# clickjacking it rides the edge-injected token, and no SameSite-cookie defense applies.
		# The app MAY frame its own-origin file previews (frame-src 'self'). HSTS is ignored by
		# browsers over plain HTTP, so sending it unconditionally is safe: it activates the
		# moment DOKTOK_SITE_ADDRESS is a TLS name. API responses carry their own (same-origin
		# framing) header set from the backend, so this block is scoped to the SPA only.
		header {
			X-Content-Type-Options "nosniff"
			X-Frame-Options "DENY"
			Referrer-Policy "no-referrer"
			Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-src 'self'; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'"
			Strict-Transport-Security "max-age=31536000; includeSubDomains"
			-Server
		}
		file_server
	}
}
